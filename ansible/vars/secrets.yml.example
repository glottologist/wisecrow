---
# Encrypt with: ansible-vault encrypt vars/secrets.yml
# Edit with:    ansible-vault edit    vars/secrets.yml

# Database
postgres_password: "REPLACE_ME_DB_PASSWORD"

# LLM provider (gloss, graded-reader, generate-exercises, seed-grammar).
# Leave blank if unused.
llm_api_key: ""

# Sync server auth (validates inbound /sync/* requests). Leave blank if
# this instance does not accept sync clients.
sync_api_key_secret: ""

# Per-host sudo password (referenced from inventory/hosts.yml as
# ansible_become_password).
become_pw_calypso: "REPLACE_ME_CALYPSO_SUDO_PW"
