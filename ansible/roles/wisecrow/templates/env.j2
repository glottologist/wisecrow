# Generated by ansible — do not edit by hand. Re-run install.yml or update.yml
# to regenerate from inventory + vault.

# ── Compose-level vars (read by docker-compose.deploy.yml) ──
POSTGRES_DB={{ postgres_db }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
WISECROW_IMAGE_TAG={{ wisecrow_image_tag }}
WISECROW_WEB_BIND={{ wisecrow_web_bind }}
WISECROW_WEB_PORT={{ wisecrow_web_port }}

# ── Application-level vars (read by the wisecrow-web container via env_file) ──
{% if llm_provider %}
WISECROW__LLM_PROVIDER={{ llm_provider }}
WISECROW__LLM_API_KEY={{ llm_api_key }}
{% endif %}
{% if unsplash_api_key %}
WISECROW__UNSPLASH_API_KEY={{ unsplash_api_key }}
{% endif %}
{% if remote_url %}
WISECROW__REMOTE_URL={{ remote_url }}
WISECROW__REMOTE_API_KEY={{ remote_api_key }}
{% endif %}
{% if sync_api_key_secret %}
WISECROW__SYNC_API_KEY={{ sync_api_key_secret }}
{% endif %}

RUST_LOG={{ rust_log }}
RUST_BACKTRACE=1
