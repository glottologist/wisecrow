# Wisecrow Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration (choose one approach)

# Option 1: Complete database URL (recommended)
WISECROW__DB_URL=postgresql://username:password@localhost/wisecrow_dev

# Option 2: Individual database components (fallback)
# WISECROW__DB_ADDRESS=localhost:5432
# WISECROW__DB_NAME=wisecrow_dev
# WISECROW__DB_USER=username
# WISECROW__DB_PASSWORD=password

# Logging Configuration
RUST_LOG=wisecrow=debug,info
RUST_BACKTRACE=1

# Development Database URLs
# DATABASE_URL=postgresql://localhost/wisecrow_dev    # Used by sqlx CLI
# TEST_DATABASE_URL=postgresql://localhost/wisecrow_test

# Optional: Download Configuration Override
# WISECROW__MAX_RETRIES=3
# WISECROW__TIMEOUT_SECONDS=300
# WISECROW__MAX_FILE_SIZE_MB=1024